{
  "name": "@mgcrea/mcp-tastytrade",
  "version": "0.8.0",
  "description": "Model Context Protocol server for the TastyTrade brokerage API",
  "keywords": [
    "brokerage",
    "mcp",
    "model-context-protocol",
    "tastytrade",
    "tastyworks",
    "trading"
  ],
  "license": "MIT",
  "author": "Olivier Louvignes <olivier@mgcrea.io>",
  "bin": {
    "tastytrade-mcp": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/cli.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "docker:build": "BUILDER=build scripts/docker-build.sh",
    "docker:buildx": "BUILDER=buildx scripts/docker-build.sh",
    "docker:push": "docker push mgcrea/mcp-tastytrade:latest && docker push mgcrea/mcp-tastytrade:$npm_package_version",
    "docker:release": "BUILDER=buildx scripts/docker-build.sh --push",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@dxfeed/dxlink-api": "^0.3.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsdown": "^0.9.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}
