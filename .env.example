# TastyTrade OAuth2 personal grant credentials
# See https://developer.tastytrade.com/oauth/ to provision
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REFRESH_TOKEN=
TASTYTRADE_SCOPE=read trade

# Either "prod" (https://api.tastyworks.com) or "cert" (https://api.cert.tastyworks.com)
TASTYTRADE_ENV=prod

# Set to "1" to enable order placement / cancellation / replacement / watchlist mutation
TASTYTRADE_ALLOW_TRADING=

# DANGER: Set to "1" to make place_order / cancel_order / replace_order / delete_watchlist
# submit immediately without the per-call confirm:true argument. Implies ALLOW_TRADING=1.
# Only use if you trust whatever's driving the MCP (and you've reviewed its prompting).
TASTYTRADE_DANGEROUSLY_ALLOW_TRADING=

# How long (ms) to keep the long-lived DXLink WebSocket open after the last quote call.
# Default 30000. Lower for fewer idle connections; higher for faster bursty workloads.
TASTYTRADE_DXLINK_IDLE_TIMEOUT_MS=

# SETUP.version string sent on the DXLink handshake. Format is
# "<protoVersion>-<clientName>/<clientVersion>". Default identifies us as
# "0.1-mcp-tastytrade-js/<ver>"; override to mimic the official SDK
# (e.g. "0.1-DXF-JS/0.3.0") if you suspect server-side client fingerprinting.
TASTYTRADE_DXLINK_VERSION=
